<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Damaka Foods</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="table.css">
</head>
<body>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
  <div class="container">
    <a class="navbar-brand fw-bold" href="#">🍔 Damaka Foods</a>
    <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#menuNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="menuNav">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link" href="das.html">Home</a></li>
        <li class="nav-item"><a class="nav-link" href="next.html">About</a></li>
        <li class="nav-item"><a class="nav-link" href="table.html">Menu</a></li>
        <li class="nav-item"><a class="nav-link" href="table1.html">Contact</a></li>
      </ul>
    </div>
  </div>
</nav>

<!-- Home -->
<section id="home" class="hero">
  <div class="container text-center">
    <h1 class="display-4 fw-bold">Welcome to Damaka Foods</h1>
    <p class="lead">50+ Delicious Foods | Fast Delivery | Best Taste 😋</p>
    <a href="#menu" class="btn btn-warning btn-lg">Explore Menu</a>
  </div>
</section>

<!-- About -->
<section id="about" class="py-5 bg-light">
  <div class="container text-center">
    <h2>About Us</h2>
    <p class="mt-3">
      Damaka Foods is an online food ordering platform delivering fresh, tasty,
      and affordable meals. We specialize in fast food, Indian dishes, and snacks
      prepared with quality ingredients.
    </p>
  </div>
</section>

<!-- Menu -->
<section id="menu" class="py-5">
  <div class="container">
    <h2 class="text-center mb-4">Our Menu (50+ Items)</h2>
    <div class="row" id="foodMenu">
      <!-- Food items loaded by JavaScript -->
    </div>
  </div>
</section>

<!-- Contact -->
<section id="contact" class="py-5 bg-light">
  <div class="container">
    <h2 class="text-center mb-4">Contact Us</h2>
    <form class="col-md-6 mx-auto">
      <input type="text" class="form-control mb-3" placeholder="Name" required>
      <input type="email" class="form-control mb-3" placeholder="Email" required>
      <textarea class="form-control mb-3" placeholder="Message"></textarea>
      <button class="btn btn-dark w-100">Submit</button>
    </form>
  </div>
</section>

<!-- Footer -->
<footer class="bg-dark text-white text-center p-3">
  © 2026 Damaka Foods | All Rights Reserved
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="script.js"></script>
<script>
    const foodNames = [
  "Burger","Pizza","Biryani","Fried Chicken","Shawarma","Sandwich",
  "Pasta","Noodles","Dosa","Idli","Parotta","Paneer",
  "Ice Cream","Cake","Juice","Coffee","Tea","Rolls",
  "Taco","Nachos","Fries","Momos","Samosa","Pav Bhaji",
  "Chicken Curry","Fish Fry","Grill Chicken","Salad","Soup",
  "Veg Thali","Non Veg Thali","Kebab","Pani Puri","Chaat",
  "Butter Chicken","Dal Tadka","Veg Curry","Egg Curry",
  "Milkshake","Falooda","Brownie","Cupcake","Donut",
  "Hot Dog","Spring Roll","Manchurian","Fried Rice"
]; // 50 items

const menu = document.getElementById("foodMenu");

foodNames.forEach((food, index) => {
  menu.innerHTML += `
    <div class="col-md-4 col-lg-3 mb-4">
      <div class="card h-100 text-center">
        <img 
          src="https://picsum.photos/seed/food${index}/400/300" 
          class="card-img-top"
          alt="${food}">
        <div class="card-body">
          <h6 class="card-title">${food}</h6>
          <p class="card-text">₹${150 + index}</p>
          <button class="btn btn-success btn-sm" onclick="orderFood('${food}')">
            Order Now
          </button>
        </div>
      </div>
    </div>
  `;
});

function orderFood(item) {
  alert(item + " added to cart 🛒");
}

</script>
</body>
</html>
